# n8n Configuration
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Ngrok Configuration (Optional but recommended for exposing webhooks)
NGROK_AUTHTOKEN=your_ngrok_token_here

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# Webhook URLs
NGROK_URL=https://your-ngrok-url.ngrok-free.dev
WEBHOOK_START_URL=${NGROK_URL}/webhook/assembly-guide
WEBHOOK_NEXT_URL=${NGROK_URL}/webhook/assembly-guide/next
