# Supabase (required for /api/models)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firebase Admin for token verification (see dependencies.py)
# Download your service account key from Firebase Console
# GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json

# OpenRouter / NVIDIA API Key (Required for free Nemotron model)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Hugging Face Space (YOLO detector)
HF_SPACE_URL=https://your-space-name.hf.space
HF_TOKEN=your-hf-read-token-here (optional, required if Space is Private)

